<Page x:Class="Park.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Park.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация">

    <Grid Background="#1a1a2e">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="Парк развлечений"
                       FontSize="24" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Логин" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="LoginBox"
                     Height="35" FontSize="14"
                     Padding="8,5"
                     Margin="0,0,0,15"/>

            <TextBlock Text="Пароль" Foreground="White" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="35" FontSize="14"
                         Padding="8,5"
                         Margin="0,0,0,25"/>

            <Button x:Name="LoginButton"
                    Content="Войти"
                    Height="40" FontSize="16"
                    Background="#e94560" Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="LoginButton_Click"/>

            <TextBlock x:Name="ErrorText"
                       Foreground="Red"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Page>