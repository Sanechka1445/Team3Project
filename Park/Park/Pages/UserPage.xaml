<Page x:Class="Park.Pages.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Park.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Пользователи">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="70"></RowDefinition>
        </Grid.RowDefinitions>

        <Button Grid.Row="1" HorizontalAlignment="Left" Click="BtnAddUser_Click" Content="Добавить пользователя" x:Name="BtnAddUser" FontSize="15" Width="200" Height="50"/>
        <Button Grid.Row="1" HorizontalAlignment="Right" Click="BtnSaveChanges_CLick" Content="Сохранить изменения" x:Name="BtnSaveChanges" FontSize="15" Width="200" Height="50"/>

        <DataGrid Grid.Row="0" x:Name="UserDataGrid" AutoGenerateColumns="False" FontSize="8" BorderBrush="DarkViolet" Foreground="DarkViolet">
            <DataGrid.Columns>
                <DataGridTextColumn Width="*" Binding="{Binding LastName}" Header="Фамилия"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Binding="{Binding FirstName}" Header="Имя"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Binding="{Binding Patronymic}" Header="Отчество"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Binding="{Binding PhoneNumber}" Header="Номер телефона"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Binding="{Binding Address}" Header="Адрес"></DataGridTextColumn>
                <DataGridCheckBoxColumn Width="*" Binding="{Binding Block}" Header="Заблокирован?"></DataGridCheckBoxColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
